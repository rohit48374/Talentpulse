# TalentPulse HRMS - Environment Configuration
# Copy this file to .env and fill in your actual values

# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Database Configuration (SQLite for development)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# PostgreSQL Configuration (for production)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=talentpulse_db
# DB_USER=postgres
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=5432

# JWT Authentication
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@talentpulse.com

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=False

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/

# AWS Configuration (if using S3 for media storage)
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=us-east-1

# Frontend URL for links in emails
FRONTEND_URL=http://localhost:3000

# Celery Configuration (for async tasks)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
